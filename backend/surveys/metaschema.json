{
  "$defs": {
    "compound_condition": {
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "items": {
            "$ref": "#/$defs/condition"
          },
          "minItems": 2,
          "type": "array"
        },
        "operator": {
          "enum": [
            "and",
            "or"
          ],
          "type": "string"
        }
      },
      "required": [
        "operator",
        "conditions"
      ],
      "type": "object"
    },
    "condition": {
      "oneOf": [
        {
          "$ref": "#/$defs/simple_condition"
        },
        {
          "$ref": "#/$defs/compound_condition"
        }
      ]
    },
    "field": {
      "additionalProperties": false,
      "properties": {
        "condition": {
          "$ref": "#/$defs/condition"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/field"
          },
          "type": "array"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "type": {
          "enum": [
            "string",
            "number",
            "boolean",
            "array"
          ],
          "type": "string"
        },
        "ui": {
          "additionalProperties": false,
          "properties": {
            "activeText": {
              "type": "string"
            },
            "choices": {
              "items": {
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "value": {}
                },
                "required": [
                  "value",
                  "label"
                ],
                "type": "object"
              },
              "minItems": 1,
              "type": "array"
            },
            "hint": {
              "type": "string"
            },
            "inactiveText": {
              "type": "string"
            },
            "placeholder": {
              "type": "string"
            },
            "textarea": {
              "type": "boolean"
            },
            "widget": {
              "enum": [
                "input",
                "number",
                "select",
                "radio",
                "checkboxes",
                "switch",
                "date"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "validation": {
          "additionalProperties": false,
          "properties": {
            "max": {
              "type": [
                "number",
                "string"
              ]
            },
            "maxLength": {
              "type": "integer"
            },
            "min": {
              "type": [
                "number",
                "string"
              ]
            },
            "minLength": {
              "type": "integer"
            },
            "required_if": {
              "$ref": "#/$defs/condition"
            }
          },
          "type": "object"
        },
        "vocabulary": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "label"
      ]
    },
    "page": {
      "additionalProperties": false,
      "properties": {
        "fields": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "fields"
      ],
      "type": "object"
    },
    "simple_condition": {
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string"
        },
        "operator": {
          "enum": [
            "eq",
            "neq",
            "in",
            "not_in"
          ],
          "type": "string"
        },
        "value": {}
      },
      "required": [
        "field",
        "operator",
        "value"
      ],
      "type": "object"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "fields": {
      "items": {
        "$ref": "#/$defs/field"
      },
      "minItems": 1,
      "type": "array"
    },
    "pages": {
      "items": {
        "$ref": "#/$defs/page"
      },
      "minItems": 1,
      "type": "array"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "fields"
  ],
  "type": "object"
}
